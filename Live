// LIVE VIDEO SYSTEM (INSTAGRAM-LIKE)

// MODEL FOR LIVE SESSION
const LiveSession = mongoose.model("LiveSession", {
  userId: String,
  title: String,
  viewers: [String],
  isActive: { type: Boolean, default: true },
  createdAt: { type: Date, default: Date.now }
});

// START LIVE SESSION
app.post("/live/start", async (req, res) => {
  const { userId, title } = req.body;

  const live = new LiveSession({ userId, title });
  await live.save();

  io.emit("liveStarted", live);

  res.json({ message: "Live started", live });
});

// END LIVE SESSION
app.post("/live/end/:liveId", async (req, res) => {
  const live = await LiveSession.findById(req.params.liveId);
  if (!live) return res.status(404).send("Live session not found");

  live.isActive = false;
  await live.save();

  io.emit("liveEnded", live);

  res.json({ message: "Live ended", live });
});

// JOIN LIVE (REALTIME)
io.on("connection", (socket) => {
  socket.on("joinLive", ({ liveId, userId }) => {
    socket.join("live_" + liveId);
    LiveSession.findByIdAndUpdate(liveId, { $addToSet: { viewers: userId } }).exec();
    io.to("live_" + liveId).emit("viewerJoined", userId);
  });

  socket.on("leaveLive", ({ liveId, userId }) => {
    socket.leave("live_" + liveId);
    LiveSession.findByIdAndUpdate(liveId, { $pull: { viewers: userId } }).exec();
    io.to("live_" + liveId).emit("viewerLeft", userId);
  });

  socket.on("liveComment", async ({ liveId, userId, text }) => {
    io.to("live_" + liveId).emit("liveComment", { userId, text });
  });
});
