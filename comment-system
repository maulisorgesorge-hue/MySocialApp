// EDIT COMMENT
app.post("/comment/edit/:postId/:commentId", async (req, res) => {
  const { userId, text } = req.body;

  const post = await Post.findById(req.params.postId);

  const comment = post.comments.find(c => c._id.toString() === req.params.commentId);

  if (comment.userId !== userId) return res.status(403).send("Not allowed");

  comment.text = text;

  await post.save();

  res.json({
    message: "Comment Updated",
    comment: comment
  });
});


// CLEAR ALL COMMENTS
app.post("/comments/clear/:postId", async (req, res) => {
  const post = await Post.findById(req.params.postId);

  post.comments = [];

  await post.save();

  res.json({
    message: "All Comments Cleared",
    totalComments: 0
  });
});
